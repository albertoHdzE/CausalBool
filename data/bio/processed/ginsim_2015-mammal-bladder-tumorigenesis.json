  "logic": {
    "Proliferation": "OR(AND(NOT(CyclinE1), CyclinA), CyclinE1)",
    "Apoptosis": "AND(LEQ(E2F1, 1), TP53)",
    "Growth_Arrest": "OR(AND(NOT(RB1), NOT(RBL2), p21CIP), AND(NOT(RB1), RBL2), RB1)",
    "EGFR": "OR(AND(NOT(EGFR_stimulus), NOT(FGFR3), NOT(GRB2), SPRY), AND(EGFR_stimulus, NOT(FGFR3), NOT(GRB2)))",
    "FGFR3": "AND(FGFR3_stimulus, NOT(EGFR), NOT(GRB2))",
    "RAS": "OR(AND(NOT(EGFR), NOT(FGFR3), GRB2), AND(NOT(EGFR), FGFR3), EGFR)",
    "E2F1": "OR(AND(NOT(RAS), E2F3, NOT(RB1), NOT(RBL2)), AND(NOT(RAS), EQ(E2F3, 2), NOT(RB1), NOT(RBL2), LEQ(ATM, 1)), AND(NOT(RAS), EQ(E2F3, 2), NOT(RB1), NOT(RBL2), EQ(ATM, 2), LEQ(CHEK1_2, 1)), AND(RAS, NOT(RB1), NOT(RBL2), LEQ(ATM, 1)), AND(RAS, NOT(RB1), NOT(RBL2), EQ(ATM, 2), LEQ(CHEK1_2, 1)))",
    "E2F3": "AND(RAS, NOT(RB1), LEQ(CHEK1_2, 1))",
    "CyclinD1": "OR(AND(NOT(RAS), NOT(p16INK4a), NOT(p21CIP), AKT), AND(RAS, NOT(p16INK4a), NOT(p21CIP)))",
    "CyclinE1": "OR(AND(NOT(E2F1), E2F3, CDC25A, NOT(RBL2), NOT(p21CIP)), AND(E2F1, CDC25A, NOT(RBL2), NOT(p21CIP)))",
    "CyclinA": "OR(AND(NOT(E2F1), E2F3, CDC25A, NOT(RBL2), NOT(p21CIP)), AND(E2F1, CDC25A, NOT(RBL2), NOT(p21CIP)))",
    "CDC25A": "OR(AND(NOT(E2F1), E2F3, NOT(RBL2), NOT(CHEK1_2)), AND(E2F1, NOT(RBL2), NOT(CHEK1_2)))",
    "p16INK4a": "AND(GrowthInhibitors, NOT(RB1))",
    "RB1": "AND(NOT(CyclinD1), NOT(CyclinE1), NOT(CyclinA), NOT(p16INK4a))",
    "RBL2": "AND(NOT(CyclinD1), NOT(CyclinE1))",
    "p21CIP": "OR(AND(NOT(GrowthInhibitors), NOT(CyclinE1), TP53, NOT(AKT)), AND(GrowthInhibitors, NOT(CyclinE1), NOT(AKT)))",
    "ATM": "AND(DNAdamage, NOT(E2F1))",
    "CHEK1_2": "AND(NOT(E2F1), ATM)",
    "MDM2": "OR(AND(NOT(RB1), NOT(ATM), NOT(TP53), NOT(p14ARF), AKT), AND(NOT(RB1), NOT(ATM), TP53, NOT(p14ARF)))",
    "TP53": "OR(AND(LEQ(E2F1, 1), ATM, CHEK1_2, NOT(MDM2)), AND(EQ(E2F1, 2), NOT(MDM2)))",
    "p14ARF": "E2F1",
    "PTEN": "TP53",
    "PI3K": "AND(RAS, NOT(PTEN), GRB2)",
    "AKT": "PI3K",
    "GRB2": "OR(AND(NOT(EGFR), FGFR3, NOT(GRB2), NOT(SPRY)), EGFR)",
    "SPRY": "RAS",
    "EGFR_stimulus": "INPUT",
    "FGFR3_stimulus": "INPUT",
    "DNAdamage": "INPUT",
    "GrowthInhibitors": "INPUT"
