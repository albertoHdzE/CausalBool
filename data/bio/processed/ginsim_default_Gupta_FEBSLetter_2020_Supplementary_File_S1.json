  "logic": {
    "ATM": "DNA_Damage & (!HDAC1 | !Wip1 | E2F1)",
    "Mdm2": "(!Wip1 | p53) & !ATM",
    "p53": "(ATM | !Sirt_1) & !Mdm2",
    "Wip1": "p53_A & !miR_16",
    "p53_A": "!Sirt_1 & !p53_K & (p53:1 | !p53INP1)",
    "p53_K": "!p53_A & (!Sirt_1 | !Wip1) & p53",
