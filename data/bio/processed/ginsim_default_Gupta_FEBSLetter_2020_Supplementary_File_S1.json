    "RB": "!CDK46_CycD & !CDK2_CycE",
    "E2F1": "(!RB & ((Cdc25A & ATM) | !Sirt_1 | !miR_34a)) | c_Myc",
    "Sirt_1": "E2F1 & !(miR_34a & HDAC1)",
    "HDAC1": "(!miR_34a & !Sirt_1) | !DNA_Damage",
    "BMI1": "!miR_16 & (E2F1 | c_Myc)",
    "PUMA": "p53_K",
    "BCL2": "!PUMA & !miR_34a & !miR_16",
    "BAX": "!BCL2 & (p53_K | c_Myc)",
    "Caspase3": "!(BCL2 & p21) & BAX",
    "Poliferation": "CDK2_CycE",
    "Senescence": "p21 & !CDK2_CycE",
