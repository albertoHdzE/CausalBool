  "logic": {
    "PP2ACdc55": "!(!SeparaseEsp1 | (SeparaseEsp1:1 & SecurinPds1))",
    "ORI": "(Clb5 & !Sic1) | ((Clb2:2 | Clb2:3) & !(Sic1 | Cdc6)) | (ORI & (Clb5:3 | Clb2:3 | (Clb5:1 & !Sic1) | (Clb2:1 & !(Sic1 | Cdc6))))",
    "Mpk1": "!BUD",
    "Net1": "((Cdc14 & Net1 & !(Clb2 & !(Sic1 | Cdc6)) & !PP2ACdc55) | (PP2ACdc55:1 & ((!Cdc14 & Clb2:2 & !(Sic1 | Cdc6)) | (Cdc14 & Clb2:2 & !(Sic1 | Cdc6))))) & !(((Cdc15:1 & Tem1) | Cdc15:2) & !Bub2-Bfa1)",
    "Tem1": "Lte1",
    "Cln3": "MASS",
    "MBF_SBF": "!(Clb2 & !(Sic1 | Cdc6)) & (Bck2 | Cln3 | Cln2 | (Clb5 & !Sic1))",
    "Cln2": "MASS & MBF_SBF",
    "Hsl1": "BUD",
    "Mad2": "ORI & !SPN",
    "Mih1": "(Mpk1 & Clb2 & !(Sic1 | Cdc6)) | (!Mpk1 & (!Clb2 | Sic1 | Cdc6))",
    "SPN": "Clb2 & !(Sic1 | Cdc6) & !CYTOKINESIS",
    "Sic1": "(!Cdc14 | (Cdc14:1 & Net1) | ((Cdc14:2 | Cdc14:3) & Net1:3)) & !Swi5 & !((Clb2 & !(Sic1 | Cdc6)) | (Clb5 & !Sic1) | Cln2 | ((Clb2 | Clb5) & (Cln3 | Bck2:2)) | (Clb5 & Clb2) | (Clb5:3 & Bck2))",
    "Cdc20": "!Mad2 & Mcm1 & !(Clb2 & !(Sic1 | Cdc6))",
    "Cdc15": "!(Clb2 & !(Sic1 | Cdc6)) | (Cdc14 & !Net1)",
    "Clb5": "MASS & MBF_SBF & Cdc20",
    "Bck2": "MASS",
    "BUD": "(Cln2 | (Clb5 & !Sic1)) & !CYTOKINESIS",
    "Lte1": "(Clb2 & !(Sic1 | Cdc6)) | SPN",
    "Cdc6": "(!Cdc14 | (Cdc14:1 & Net1) | ((Cdc14:2 | Cdc14:3) & Net1:3)) & !Swi5 & !((Clb2 & !(Sic1 | Cdc6)) | (Clb5 & !Sic1) | Cln2 | ((Clb2 | Clb5) & (Cln3 | Bck2:2)) | (Clb5 & Clb2) | (Clb5:3 & Bck2))",
    "Bub2-Bfa1": "ORI & (!SPN | PP2ACdc55 | !Cdc5Polo)",
    "Cdc5Polo": "Clb2 & !(Sic1 | Cdc6) & !Cdh1",
    "Mcm1": "Clb2 & !(Sic1 | Cdc6)",
    "SecurinPds1": "(Mcm1 & MBF_SBF & !Cdc20) | ((Mcm1 | MBF_SBF) & !Cdh1 & !Cdc20)",
    "Swe1": "MBF_SBF & ((Clb2 & !(Sic1 | Cdc6) & !Hsl1) | (Hsl1 & !Clb2) | Sic1 | Cdc6)",
    "Cdh1": "(!Cdc14 | (Cdc14:1 & Net1) | ((Cdc14:2 | Cdc14:3) & Net1:3)) & !((Clb2 & !(Sic1 | Cdc6)) | (Clb5 & !Sic1) | (Cln3 & Cln2))",
    "Swi5": "(Mcm1 & !(Clb2 & !(Sic1 | Cdc6))) | (Mcm1 & Clb2 & !(Sic1 | Cdc6) & ((Cdc14:1 & !Net1) | (Cdc14:2 & !Net1:3)))",
    "CYTOKINESIS": "MASS & Clb2:2 & !(Sic1 | Cdc6)",
    "Clb2": "((MASS:1 & ((Swe1:1 & !Mih1:2) | (Swe1:2 & Mih1:1))) | (MASS & Swe1:2 & !Mih1)) & !Cdh1 & (!Cdc20 | (Cdc20:2 & Mcm1))"
