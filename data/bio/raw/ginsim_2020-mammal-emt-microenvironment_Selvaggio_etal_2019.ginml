0 = lack of adherens junction formation
1 = adherens junction formation, by the formation of the complex E-cadherin-β-catenin-p120 at the membrane "
</comment>
      </annotation>
      <nodevisualsetting x="2061" y="1273" style="Epithelial marker multi-valued"/>
    </node>
    <node id="FA" maxvalue="3">
      <parameter idActiveInteractions=" PAK:FA FAK_SRC:FA ITG_AB:FA" val="3"/>
      <parameter idActiveInteractions=" PAK:FA FAK_SRC:FA" val="2"/>
