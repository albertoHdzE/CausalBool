          <link xlink:href="https://www.ncbi.nlm.nih.gov/pubmed/?term=15899849"/>
        </linklist>
        <comment>This node represents the RAS exchange factor RASGRP1, an important activator of RAS during TCR activation [2].
</comment>
      </annotation>
      <nodevisualsetting x="1221" y="511" style=""/>
    </node>
    <node id="SOS" maxvalue="1">
      <value val="1">
        <exp str="GRB2 &amp; RAS"/>
      </value>
