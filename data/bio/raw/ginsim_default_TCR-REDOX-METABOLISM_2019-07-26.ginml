          <link xlink:href="https://www.ncbi.nlm.nih.gov/pubmed/?term=14966303"/>
        </linklist>
        <comment>This node represents the Plasma Membrane Calcium ATPase. It is a pump that extrudes calcium and modulates its cytoplasmic concentration [2], [3].</comment>
      </annotation>
      <nodevisualsetting x="1752" y="665" style=""/>
    </node>
    <node id="ORAI1" maxvalue="1">
