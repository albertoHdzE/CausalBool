          <link xlink:href="https://www.ncbi.nlm.nih.gov/pubmed/?term=11994416"/>
          <link xlink:href="https://www.ncbi.nlm.nih.gov/pubmed/?term=17050525"/>
          <link xlink:href="https://www.ncbi.nlm.nih.gov/pubmed/?term=10849438"/>
        </linklist>
        <comment>This node represents the signaling protein VAV1, important in the early TCR signaling events [2], [3], [4].</comment>
      </annotation>
      <nodevisualsetting x="1229" y="402" style=""/>
    </node>
    <node id="RASGRP" maxvalue="1">
