          <link xlink:href="https://www.ncbi.nlm.nih.gov/pubmed/?term=17283063"/>
        </linklist>
        <comment>This node represents the RAS activator protein SOS. It is an important mediator of the TCR signals [2], [3].</comment>
      </annotation>
      <nodevisualsetting x="969" y="520" style=""/>
    </node>
    <node id="GRB2" maxvalue="1">
      <value val="1">
        <exp str="LAT"/>
      </value>
      <annotation>
        <linklist>
          <link xlink:href="https://www.genenames.org/data/gene-symbol-report/#!/hgnc_id/HGNC:4566"/>
          <link xlink:href="https://www.ncbi.nlm.nih.gov/pubmed/?term=9846483"/>
          <link xlink:href="https://www.ncbi.nlm.nih.gov/pubmed/?term=8479536"/>
        </linklist>
        <comment>This node represent the early TCR signaling protein GRB2 involved in the LAT signalosome.</comment>
      </annotation>
      <nodevisualsetting x="998" y="326" style=""/>
    </node>
    <node id="PLCg" maxvalue="1">
      <value val="1">
        <exp str="SLP76 &amp; ITK &amp; LAT"/>
      </value>
      <annotation>
        <linklist>
          <link xlink:href="https://www.genenames.org/data/gene-symbol-report/#!/hgnc_id/HGNC:9065"/>
          <link xlink:href="https://www.ncbi.nlm.nih.gov/pubmed/?term=17148460"/>
          <link xlink:href="https://www.ncbi.nlm.nih.gov/pubmed/?term=11994416"/>
        </linklist>
        <comment>This node represents the phospholipase C gamma, an important signaling protein connecting the TCR signals with the downstream calcium currents [2], [3].</comment>
      </annotation>
      <nodevisualsetting x="1402" y="333" style=""/>
    </node>
    <node id="PI3K" maxvalue="1">
