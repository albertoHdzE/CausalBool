          <link xlink:href="https://www.ncbi.nlm.nih.gov/pubmed/?term=9584150"/>
          <link xlink:href="https://www.ncbi.nlm.nih.gov/pubmed/?term=15771581"/>
        </linklist>
        <comment>This node represents the Tec family kinase ITK. It is an important mediator of the early TCR signals [2], [3], [4].</comment>
      </annotation>
      <nodevisualsetting x="1227" y="207" style=""/>
    </node>
    <node id="VAV1" maxvalue="1">
      <value val="1">
