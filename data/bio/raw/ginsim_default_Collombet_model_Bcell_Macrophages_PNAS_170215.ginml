        </linklist>
        <comment>Favor myeloid over lymphoid differentiation by repressing Gfi1
[Spooner et al (2009) Immunity 31:576-86]</comment>
      </annotation>
      <nodevisualsetting x="562" y="427" style="Mac"/>
    </node>
    <node id="Cebpb" name="CEBPb" maxvalue="1">
      <value val="1">
        <exp str="Spi1:2 &amp; (Cebpa | Cebpb)"/>
