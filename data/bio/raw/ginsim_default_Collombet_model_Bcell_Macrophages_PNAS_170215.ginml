          <link xlink:href=""/>
        </linklist>
        <comment>LMPP phenotype marker.
</comment>
      </annotation>
      <nodevisualsetting x="537" y="789" style="Progenitor"/>
    </node>
    <node id="Mef2c" name="Mef2c" maxvalue="1">
      <value val="1">
        <exp str="Spi1 &amp; !(Cebpa | Cebpb)"/>
      </value>
      <annotation>
        <linklist>
          <link xlink:href="http://www.ensembl.org/Mus_musculus/Gene/Summary?db=core;g=ENSMUSG00000005583;r=13:83504034-83667080"/>
          <link xlink:href="https://www.ncbi.nlm.nih.gov/pubmed/19169261"/>
        </linklist>
        <comment>Required for CLP, B-cells and T-cells differentiation  .
[Stehling-Sun S et al. (2009) Nature immunology, 10(3)]



</comment>
      </annotation>
      <nodevisualsetting x="497" y="130" style="Progenitor"/>
    </node>
    <node id="Ets1" name="Ets1" maxvalue="1">
      <value val="1">
        <exp str="E2a_prot_Active"/>
      </value>
      <annotation>
