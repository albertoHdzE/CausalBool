          <link xlink:href=""/>
        </linklist>
        <comment>see Cd19 node for annotation.</comment>
      </annotation>
      <nodevisualsetting x="763" y="812" style="Bcell (small)"/>
    </node>
    <node id="Cd19" maxvalue="1">
      <value val="1">
        <exp str="Cd19_gene"/>
      </value>
