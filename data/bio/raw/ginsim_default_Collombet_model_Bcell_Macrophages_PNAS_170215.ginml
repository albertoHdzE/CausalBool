      <value val="1">
        <exp str="E2a_prot_Active &amp; Foxo1 &amp; Ets1 &amp; Runx1 &amp; Spi1 &amp; Il7r_act &amp; !(Cebpa | Cebpb)"/>
        <exp str="E2a_prot_Active &amp; Foxo1 &amp; Ets1 &amp; Pax5_prot_active &amp; Ebf1 &amp; !(Cebpa | Cebpb)"/>
      </value>
