          <link xlink:href="http://www.uniprot.org/uniprot/P45985"/>
          <link xlink:href="http://www.genenames.org/cgi-bin/gene_symbol_report?hgnc_id=HGNC:6847"/>
          <link xlink:href="http://www.genenames.org/cgi-bin/gene_symbol_report?hgnc_id=HGNC:6844"/>
          <link xlink:href="http://www.ncbi.nlm.nih.gov/gene/6416"/>
          <link xlink:href="http://www.ncbi.nlm.nih.gov/gene/5609"/>
          <link xlink:href="http://www.ncbi.nlm.nih.gov/pubmed/?term=9712046"/>
        </linklist>
        <comment>MEKK4/7 lie downstream of MEKK1 and upstream of JNK in the VAV-JNK signalling cascade.
(Kawakami et al., 1998)
</comment>
      </annotation>
      <nodevisualsetting x="247" y="595" style="Reduced node 3"/>
    </node>
    <node id="NFAT" maxvalue="1">
      <value val="1">
        <exp str="CALCINEURIN"/>
      </value>
      <annotation>
        <linklist>
          <link xlink:href="http://www.uniprot.org/uniprot/O95644"/>
