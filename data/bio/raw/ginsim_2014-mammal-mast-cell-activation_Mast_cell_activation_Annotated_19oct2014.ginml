      </value>
      <annotation>
        <linklist>
          <link xlink:href="http://www.genenames.org/cgi-bin/gene_symbol_report?hgnc_id=HGNC:7794"/>
          <link xlink:href="http://www.uniprot.org/uniprot/P19838"/>
          <link xlink:href="http://www.ncbi.nlm.nih.gov/gene/4790"/>
