          <link xlink:href="https://www.uniprot.org/uniprot/P05112"/>
          <link xlink:href="https://pubmed.ncbi.nlm.nih.gov/16540365/"/>
        </linklist>
        <comment>Gene encoding Interleukin-4 [1].
IL4 gene is regulated by STAT6 [2].</comment>
      </annotation>
      <nodevisualsetting x="1463" y="1022" style=""/>
