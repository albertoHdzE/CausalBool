      <edgevisualsetting anchor="NE" style=""/>
    </edge>
    <edge id="Smad2_3_4:FGFA" from="Smad2_3_4" to="FGFA" minvalue="1" sign="negative">
      <edgevisualsetting points="470,386" anchor="NE" style=""/>
    </edge>
