      <edgevisualsetting points="453,420" anchor="NE" style=""/>
    </edge>
    <edge id="Smad2_3_4:Goosecoid" from="Smad2_3_4" to="Goosecoid" minvalue="1" sign="positive">
      <edgevisualsetting points="433,301" anchor="NE" style=""/>
    </edge>
