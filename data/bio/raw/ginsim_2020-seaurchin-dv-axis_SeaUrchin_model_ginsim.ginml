      <edgevisualsetting points="70,220" anchor="NE" style=""/>
    </edge>
    <edge id="Smad2_3_4:Bmp2_4" from="Smad2_3_4" to="Bmp2_4" effects="1:positive 2:positive">
      <edgevisualsetting points="162,230" anchor="NE" style=""/>
    </edge>
    <edge id="Smad2_3_4:Lefty" from="Smad2_3_4" to="Lefty" minvalue="1" sign="positive">
      <edgevisualsetting points="262,240" anchor="NE" style=""/>
    </edge>
    <edge id="Smad2_3_4:Chordin" from="Smad2_3_4" to="Chordin" minvalue="1" sign="positive">
      <edgevisualsetting points="358,249" anchor="NE" style=""/>
    </edge>
    <edge id="Smad2_3_4:Smad1_4_5_8" from="Smad2_3_4" to="Smad1_4_5_8" effects="1:negative 2:negative">
      <edgevisualsetting points="815,236" anchor="NE" style=""/>
    </edge>
    <edge id="Smad2_3_4:Admp1" from="Smad2_3_4" to="Admp1" minvalue="1" sign="positive">
      <edgevisualsetting points="501,294" anchor="NE" style=""/>
    </edge>
    <edge id="Bmp2_4_In:Alk1_2_3_6" from="Bmp2_4_In" to="Alk1_2_3_6" effects="1:positive 2:positive">
      <edgevisualsetting points="925,153" anchor="NE" style=""/>
    </edge>
    <edge id="Wnt_In:Frz" from="Wnt_In" to="Frz" minvalue="1" sign="positive">
      <edgevisualsetting points="1372,111" anchor="NE" style=""/>
    </edge>
    <edge id="Brachyury:FoxA" from="Brachyury" to="FoxA" minvalue="1" sign="positive">
      <edgevisualsetting anchor="NE" style=""/>
