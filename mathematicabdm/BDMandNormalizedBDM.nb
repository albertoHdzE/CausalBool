Cell[CellGroupData[{

Cell["Normalized BDM", "Subsubsection",
 CellChangeTimes->{{3.571633234383839*^9, 3.571633238086946*^9}}],

Cell["Gives the maximum product of k natural numbers which sum n. ", "Text",
 CellChangeTimes->{{3.571978828685261*^9, 3.571978857583419*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"MaxProduct", "[", 
   RowBox[{"n_", ",", "k_"}], "]"}], ":=", 
  RowBox[{"With", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"f", " ", "=", " ", 
      RowBox[{"Floor", "[", 
       RowBox[{"n", "/", "k"}], "]"}]}], "}"}], ",", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"f", "^", 
       RowBox[{"(", 
        RowBox[{"k", "-", "n", "+", 
         RowBox[{"(", 
          RowBox[{"f", " ", "k"}], ")"}]}], ")"}]}], ")"}], 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"f", "+", "1"}], ")"}], "^", 
       RowBox[{"(", 
        RowBox[{"n", "-", 
         RowBox[{"(", 
          RowBox[{"f", " ", "k"}], ")"}]}], ")"}]}], ")"}]}]}], 
   "]"}]}]], "Input",
 CellChangeTimes->{{3.571978275073394*^9, 3.57197828379542*^9}, {
  3.571978319728669*^9, 3.571978333305471*^9}, {3.571978368441886*^9, 
  3.571978406053684*^9}, {3.571978448110686*^9, 3.571978463312766*^9}, {
