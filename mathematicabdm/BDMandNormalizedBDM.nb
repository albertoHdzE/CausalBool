 RowBox[{
  RowBox[{"sumComplexUpTo", "=", " ", 
   RowBox[{"FoldList", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"N", "@", 
       RowBox[{"(", 
        RowBox[{"#1", "+", "#2"}], ")"}]}], " ", "&"}], ",", 
     RowBox[{"decreasingComplex", "[", 
      RowBox[{"[", "1", "]"}], "]"}], ",", " ", 
