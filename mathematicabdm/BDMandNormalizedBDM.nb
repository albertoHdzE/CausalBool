Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"MaxBDMold", "[", "n_", "]"}], ":=", " ", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Plus", "@@", 
     RowBox[{"decreasingComplex", "[", 
      RowBox[{"[", 
       RowBox[{"1", ";;", 
        RowBox[{"Min", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"Floor", "[", 
            RowBox[{"n", "/", "4"}], "]"}], "^", "2"}], ",", 
          RowBox[{"2", "^", "16"}]}], "]"}]}], "]"}], "]"}]}], "+", 
    RowBox[{"Log", "[", 
     RowBox[{"2", ",", 
      RowBox[{"MaxProduct", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"Floor", "[", 
          RowBox[{"n", "/", "4"}], "]"}], "^", "2"}], ",", " ", 
        RowBox[{"Min", "[", 
