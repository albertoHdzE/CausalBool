Cell[BoxData[
 RowBox[{"(*", 
  RowBox[{
   RowBox[{"D5", "=", 
    RowBox[{"Select", "[", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"ToExpression", "/@", 
           RowBox[{"StringSplit", "[", 
            RowBox[{
             RowBox[{
             "#", "\[LeftDoubleBracket]", "1", "\[RightDoubleBracket]"}], 
             ",", "\"\<\>\""}], "]"}]}], ",", 
          RowBox[{"-", 
           RowBox[{"Log", "[", 
            RowBox[{"2", ",", 
             RowBox[{
             "#", "\[LeftDoubleBracket]", "2", "\[RightDoubleBracket]"}]}], 
            "]"}]}]}], "}"}], "&"}], "/@", 
       RowBox[{"<<", "\"\<D5.m\>\""}]}], ",", 
      RowBox[{
       RowBox[{
        RowBox[{"Length", "[", 
         RowBox[{"#", "\[LeftDoubleBracket]", "1", "\[RightDoubleBracket]"}], 
         "]"}], "\[LessEqual]", "12"}], "&"}]}], "]"}]}], ";", 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"completedD5", "=", 
    RowBox[{"Join", "[", 
     RowBox[{"D5", ",", 
      RowBox[{
       RowBox[{
        RowBox[{"Flatten", "[", 
         RowBox[{"#", ",", "1"}], "]"}], "&"}], "/@", 
       RowBox[{"Thread", "[", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"List", "/@", 
           RowBox[{"Complement", "[", 
            RowBox[{
             RowBox[{"Tuples", "[", 
              RowBox[{
               RowBox[{"{", 
                RowBox[{"0", ",", "1"}], "}"}], ",", "12"}], "]"}], ",", 
             RowBox[{"First", "/@", "D5"}]}], "]"}]}], ",", 
          RowBox[{
           RowBox[{"Max", "[", 
            RowBox[{"(", 
             RowBox[{"Last", "/@", "D5"}], ")"}], "]"}], "+", "1"}]}], "}"}], 
        "]"}]}]}], "]"}]}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"With", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"sq", "=", 
         RowBox[{"completedD5", "[", 
          RowBox[{"[", "nS", "]"}], "]"}]}], "}"}], ",", 
       RowBox[{
        RowBox[{"HashStrings", "[", 
         RowBox[{"sq", "[", 
          RowBox[{"[", "1", "]"}], "]"}], "]"}], "=", 
        RowBox[{"sq", "[", 
         RowBox[{"[", "2", "]"}], "]"}]}]}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"nS", ",", 
       RowBox[{"Length", "@", "completedD5"}]}], "}"}]}], "]"}], ";", 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"BDM", "[", 
     RowBox[{"array_", ",", "dim_"}], "]"}], ":=", 
    RowBox[{"First", "[", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"part", "=", 
         RowBox[{"Partition", "[", 
          RowBox[{"array", ",", 
           RowBox[{"{", 
            RowBox[{"dim", ",", "dim"}], "}"}]}], "]"}]}], "}"}], ",", 
       RowBox[{"Total", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{"Log", "[", 
             RowBox[{"2", ",", 
              RowBox[{"#", "[", 
               RowBox[{"[", "2", "]"}], "]"}]}], "]"}], "+", 
            RowBox[{"#", "[", 
             RowBox[{"[", "1", "]"}], "]"}]}], "}"}], "&"}], "/@", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{
            RowBox[{"{", 
             RowBox[{
              RowBox[{"HashSquares", "[", 
               RowBox[{"#", "[", 
                RowBox[{"[", "1", "]"}], "]"}], "]"}], ",", 
              RowBox[{"#", "[", 
               RowBox[{"[", "2", "]"}], "]"}]}], "}"}], "&"}], "/@", 
           RowBox[{"Tally", "[", 
            RowBox[{"Flatten", "[", 
             RowBox[{"part", ",", "1"}], "]"}], "]"}]}], ")"}]}], "]"}]}], 
      "]"}], "]"}]}]}], "*)"}]], "Input",
 CellChangeTimes->{{3.5762113753718915`*^9, 3.5762113827558155`*^9}, {
  3.5804830150021496`*^9, 3.580483033814682*^9}}],

