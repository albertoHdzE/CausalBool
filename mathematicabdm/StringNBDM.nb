Cell[CellGroupData[{

Cell["Normalization", "Subsubsection",
 CellChangeTimes->{{3.571979661134494*^9, 3.571979662852602*^9}}],

Cell["A variant of the NBDM that considers minimum and maximum", "Text",
 CellChangeTimes->{{3.571635326555488*^9, 3.571635340690891*^9}, {
  3.571635511908715*^9, 3.571635512021915*^9}, {3.576343268280328*^9, 
  3.576343277965825*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"StringNBDM", "[", "string_", "]"}], ":=", "\[IndentingNewLine]", 
  RowBox[{"If", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"StringLength", "@", "string"}], " ", "\[GreaterEqual]", " ", 
     "12"}], ",", "\[IndentingNewLine]", 
    RowBox[{"N", "@", 
     RowBox[{"Rescale", "[", 
      RowBox[{
       RowBox[{"StringBDM", "[", "string", "]"}], ",", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"MinBDM", "[", 
          RowBox[{"StringLength", "@", "string"}], "]"}], ",", 
         RowBox[{"MaxBDM", "[", 
          RowBox[{"StringLength", "@", "string"}], "]"}]}], "}"}]}], "]"}]}], 
    ",", "\[IndentingNewLine]", 
    RowBox[{"N", "@", 
     RowBox[{"Rescale", "[", 
      RowBox[{
       RowBox[{"-", 
        RowBox[{"Log", "[", 
         RowBox[{"2", ",", 
          RowBox[{
           RowBox[{"Select", "[", 
            RowBox[{"D5", ",", 
             RowBox[{
              RowBox[{
               RowBox[{"#", "[", 
                RowBox[{"[", "1", "]"}], "]"}], " ", "\[Equal]", " ", 
               "string"}], " ", "&"}], ",", "1"}], "]"}], "[", 
           RowBox[{"[", 
            RowBox[{"1", ",", "2"}], "]"}], "]"}]}], "]"}]}], ",", " ", 
       "\[IndentingNewLine]", 
       RowBox[{"With", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"s", " ", "=", " ", 
           RowBox[{
            RowBox[{
             RowBox[{"N", "[", 
              RowBox[{"-", 
               RowBox[{"Log", "[", 
                RowBox[{"2", ",", 
                 RowBox[{"#", "[", 
                  RowBox[{"[", "2", "]"}], "]"}]}], "]"}]}], "]"}], "&"}], "/@", 
            RowBox[{"Select", "[", 
             RowBox[{"D5", ",", 
              RowBox[{
               RowBox[{
                RowBox[{"StringLength", "@", 
                 RowBox[{"#", "[", 
                  RowBox[{"[", "1", "]"}], "]"}]}], " ", "\[Equal]", " ", 
                RowBox[{"StringLength", "@", "string"}]}], " ", "&"}], ",", 
              " ", 
              RowBox[{"2", "^", 
               RowBox[{"(", 
                RowBox[{"StringLength", "@", "string"}], ")"}]}]}], "]"}]}]}],
           "}"}], ",", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"Min", "@", "s"}], ",", " ", 
           RowBox[{"Max", "@", "s"}]}], "}"}]}], "]"}]}], "]"}]}]}], 
   "]"}]}]], "Input",
 CellChangeTimes->{{3.571635315223008*^9, 3.571635365756572*^9}, {
  3.571635402323388*^9, 3.571635466784744*^9}, {3.57184571914127*^9, 
  3.571845722672685*^9}, {3.571845789555432*^9, 3.571845799151413*^9}, {
  3.571845841833399*^9, 3.571845853033817*^9}, {3.576291793859004*^9, 
  3.576291905107203*^9}, {3.576291950365203*^9, 3.576291985060688*^9}, {
  3.576292105482987*^9, 3.576292208733605*^9}, {3.57634205624819*^9, 
  3.576342120376967*^9}, {3.576343031803549*^9, 3.57634303219346*^9}, {
  3.576343723396465*^9, 3.576343976619166*^9}, {3.576344057688638*^9, 
  3.57634406851335*^9}}]
