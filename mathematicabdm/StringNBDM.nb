Cell["Normalized BDM for strings", "Subsubsection",
 CellChangeTimes->{{3.571633234383839*^9, 3.571633238086946*^9}, {
  3.576341047552334*^9, 3.57634104954105*^9}}],

Cell["Gives the maximum product of k natural numbers which sum n. ", "Text",
 CellChangeTimes->{{3.571978828685261*^9, 3.571978857583419*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"MaxProduct", "[", 
   RowBox[{"n_", ",", "k_"}], "]"}], ":=", 
  RowBox[{"With", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"f", " ", "=", " ", 
      RowBox[{"Floor", "[", 
       RowBox[{"n", "/", "k"}], "]"}]}], "}"}], ",", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"f", "^", 
       RowBox[{"(", 
        RowBox[{"k", "-", "n", "+", 
         RowBox[{"(", 
          RowBox[{"f", " ", "k"}], ")"}]}], ")"}]}], ")"}], 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"f", "+", "1"}], ")"}], "^", 
       RowBox[{"(", 
        RowBox[{"n", "-", 
         RowBox[{"(", 
          RowBox[{"f", " ", "k"}], ")"}]}], ")"}]}], ")"}]}]}], 
   "]"}]}]], "Input",
 CellChangeTimes->{{3.571978275073394*^9, 3.57197828379542*^9}, {
  3.571978319728669*^9, 3.571978333305471*^9}, {3.571978368441886*^9, 
  3.571978406053684*^9}, {3.571978448110686*^9, 3.571978463312766*^9}, {
  3.571978505626852*^9, 3.571978509962633*^9}, {3.571978557684637*^9, 
  3.571978567036175*^9}, {3.571978658857752*^9, 3.571978660856921*^9}, {
  3.571978693042103*^9, 3.571978719292252*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"decreasingComplex", " ", "=", " ", 
   RowBox[{"Reverse", "@", 
    RowBox[{"Sort", "[", 
     RowBox[{"Join", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"38", ",", "38"}], "}"}], ",", 
       RowBox[{
        RowBox[{
         RowBox[{"N", "@", 
          RowBox[{"(", 
           RowBox[{"-", 
            RowBox[{"Log", "[", 
             RowBox[{"2", ",", 
              RowBox[{"#", "[", 
               RowBox[{"[", "2", "]"}], "]"}]}], "]"}]}], ")"}]}], "&"}], "/@", 
        RowBox[{"Select", "[", 
         RowBox[{"D5", ",", " ", 
          RowBox[{
           RowBox[{
            RowBox[{"StringLength", "@", 
             RowBox[{"#", "[", 
              RowBox[{"[", "1", "]"}], "]"}]}], " ", "\[Equal]", " ", "12"}], 
           " ", "&"}]}], "]"}]}]}], "]"}], "]"}]}]}], ";"}]], "Input",
 CellChangeTimes->{{3.571979365861172*^9, 3.571979366432766*^9}, {
  3.572233691679768*^9, 3.572233699970112*^9}, {3.576291611238709*^9, 
  3.576291653427058*^9}, {3.57629202857572*^9, 3.576292034906557*^9}, {
  3.576341144597886*^9, 3.57634123501464*^9}, {3.576342823023642*^9, 
  3.576342834871951*^9}, {3.576343048802062*^9, 3.57634305096043*^9}, {
  3.576343242501396*^9, 3.576343247146572*^9}}],

Cell["Sum of the n more complex squares:", "Text",
 CellChangeTimes->{{3.572233702385118*^9, 3.572233716218397*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"sumComplexUpTo", "=", " ", 
   RowBox[{"FoldList", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"N", "@", 
       RowBox[{"(", 
        RowBox[{"#1", "+", "#2"}], ")"}]}], " ", "&"}], ",", 
     RowBox[{"decreasingComplex", "[", 
      RowBox[{"[", "1", "]"}], "]"}], ",", " ", 
     RowBox[{"Rest", "@", "decreasingComplex"}]}], "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.572233721683132*^9, 3.57223375859755*^9}, {
  3.572233908115426*^9, 3.572233910580373*^9}, {3.572234106864519*^9, 
  3.572234123608979*^9}, {3.572234329334722*^9, 3.572234371047919*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"MaxBDM", "[", "stringLength_", "]"}], ":=", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"sumComplexUpTo", "[", 
     RowBox[{"[", 
      RowBox[{"Min", "[", 
       RowBox[{
        RowBox[{"Floor", "[", 
         RowBox[{"stringLength", "/", "12"}], "]"}], ",", 
        RowBox[{"2", "^", "12"}]}], "]"}], "]"}], "]"}], "+", 
    RowBox[{"Log", "[", 
     RowBox[{"2", ",", 
      RowBox[{"MaxProduct", "[", 
       RowBox[{
        RowBox[{"Floor", "[", 
         RowBox[{"stringLength", "/", "12"}], "]"}], ",", " ", 
        RowBox[{"Min", "[", 
         RowBox[{
          RowBox[{"Floor", "[", 
           RowBox[{"stringLength", "/", "12"}], "]"}], ",", 
          RowBox[{"2", "^", "12"}]}], "]"}]}], " ", "]"}]}], "]"}]}]}], 
  ";"}]], "Input",
 CellChangeTimes->{{3.572233680469105*^9, 3.572233685896763*^9}, {
  3.57223377789488*^9, 3.572233806993778*^9}, {3.576341293700512*^9, 
  3.576341353323644*^9}}]
}, Open  ]],

Cell[CellGroupData[{

Cell["Minimum value for BDM", "Subsubsection",
 CellChangeTimes->{{3.57163516290982*^9, 3.571635167745838*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"MinBDM", "[", "stringLength_", "]"}], ":=", " ", 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"Last", "@", "decreasingComplex"}], "+", " ", 
   RowBox[{"Log", "[", 
    RowBox[{"2", ",", 
     RowBox[{"Floor", "[", 
      RowBox[{"stringLength", "/", "12"}], "]"}]}], "]"}]}]}]], "Input",
