Cell[BoxData[
 RowBox[{
  RowBox[{"StringBDM", "[", 
   RowBox[{"string_", ",", 
    RowBox[{"len_:", "1"}]}], "]"}], ":=", " ", "\[IndentingNewLine]", 
  RowBox[{"N", "@", 
   RowBox[{"Total", "[", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"HashStrings", "[", 
        RowBox[{"#", "[", 
         RowBox[{"[", "1", "]"}], "]"}], "]"}], "+", 
       RowBox[{"Log", "[", 
        RowBox[{"2", ",", 
         RowBox[{"#", "[", 
          RowBox[{"[", "2", "]"}], "]"}]}], "]"}]}], "&"}], "/@", 
     RowBox[{"Tally", "[", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"TrueQ", "[", 
         RowBox[{
          RowBox[{"StringLength", "[", "string", "]"}], ">", "12"}], "]"}], 
        ",", 
        RowBox[{"StringPartition", "[", 
         RowBox[{"string", ",", "12", ",", "len"}], "]"}], ",", 
        RowBox[{"{", "string", "}"}]}], "]"}], "]"}]}], "]"}]}]}]], "Input",
 CellChangeTimes->{3.73118093049841*^9, 3.731181185599428*^9}],

