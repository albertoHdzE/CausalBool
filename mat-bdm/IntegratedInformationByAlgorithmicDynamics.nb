Cell["Causal calculus:", "Subsection",
 CellChangeTimes->{{3.7422363160718613`*^9, 
  3.742236318584783*^9}},ExpressionUUID->"57c37ca5-ff84-41d5-b52f-\
f2dfc92c5469"],

Cell[BoxData[
 RowBox[{
  RowBox[{"CalculateInformationEdgesBDM", "[", "graph_", "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"mutatedgraphs", "=", 
      RowBox[{"AdjacencyMatrix", "/@", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{
          RowBox[{"EdgeDelete", "[", 
           RowBox[{"graph", ",", "#"}], "]"}], "&"}], "/@", 
         RowBox[{"EdgeList", "[", "graph", "]"}]}], ")"}]}]}], "}"}], ",", 
    RowBox[{"Reverse", "[", 
     RowBox[{"SortBy", "[", 
      RowBox[{
       RowBox[{"Thread", "[", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"EdgeList", "[", "graph", "]"}], ",", 
          RowBox[{
           RowBox[{"BDM", "[", 
            RowBox[{"AdjacencyMatrix", "@", "graph"}], "]"}], "-", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{
              RowBox[{"N", "/@", 
               RowBox[{"BDM", "[", "#", "]"}]}], "&"}], "/@", 
             "mutatedgraphs"}], ")"}]}]}], "}"}], "]"}], ",", "Last"}], "]"}],
      "]"}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.60828168067321*^9, 3.608281695196663*^9}, {
  3.641802124288992*^9, 3.6418021269886417`*^9}, {3.641802590629767*^9, 
  3.6418026001311073`*^9}, {3.6420467991288033`*^9, 
  3.642046801955121*^9}},ExpressionUUID->"006a8a62-40b4-4135-bc42-\
2b6c299e3946"],

Cell[BoxData[
 RowBox[{
  RowBox[{"CalculateInformationEdgesCompress", "[", "graph_", "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"mutatedgraphs", "=", 
      RowBox[{"AdjacencyMatrix", "/@", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{
          RowBox[{"EdgeDelete", "[", 
           RowBox[{"graph", ",", "#"}], "]"}], "&"}], "/@", 
         RowBox[{"EdgeList", "[", "graph", "]"}]}], ")"}]}]}], "}"}], ",", 
    RowBox[{"Reverse", "[", 
     RowBox[{"SortBy", "[", 
      RowBox[{
       RowBox[{"Thread", "[", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"EdgeList", "[", "graph", "]"}], ",", 
          RowBox[{
           RowBox[{"ByteCount", "@", 
            RowBox[{"Compress", "[", 
             RowBox[{
              RowBox[{"AdjacencyMatrix", "@", "graph"}], ",", "4"}], "]"}]}], 
           "-", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{
              RowBox[{"ByteCount", "@", 
               RowBox[{"Compress", "[", 
                RowBox[{"#", ",", "4"}], "]"}]}], "&"}], "/@", 
             "mutatedgraphs"}], ")"}]}]}], "}"}], "]"}], ",", "Last"}], "]"}],
      "]"}]}], "]"}]}]], "Input",ExpressionUUID->"8b46b595-daa7-4d18-9d2b-\
448571299917"],

